# AutoQuantum Environment Configuration
# Copy this file to .env and adjust values as needed.

# ============================================
# Project Configuration
# ============================================

# Container path to project directory (default: /workspace/autoquantum)
#PROJECT_ROOT=/workspace/autoquantum

# Lean project path inside container (default: /workspace/autoquantum/lean)
#LEAN_PROJECT_PATH=/workspace/autoquantum/lean

# Lean library target name (default: AutoQuantum)
#LEAN_TARGET=AutoQuantum

# Lean tools repository root (default: /workspace/autoquantum)
#LEAN_TOOLS_REPO_ROOT=/workspace/autoquantum

# Note: docker-compose mounts the host ./ directory to /workspace/autoquantum in the container.
# ============================================
# Model Configuration (Optional)
# ============================================

# Optional default model (not used by OpenCode; can be used by custom scripts)
# Format: provider/model (e.g., deepseek/deepseek-reasoner, anthropic/claude-3-5-sonnet)
MODEL=deepseek/deepseek-reasoner

# ============================================
# OpenCode Server Settings
# ============================================

# Host interface to bind OpenCode server (default: 0.0.0.0)
OPENCODE_HOST=0.0.0.0

# Port for OpenCode server (default: 4096)
OPENCODE_PORT=4096

# ============================================
# API Keys (Required for LLM providers)
# ============================================

# DeepSeek API key (for deepseek/deepseek-reasoner and other DeepSeek models)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Anthropic API key (for Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API key (for GPT models)
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# Optional Settings
# ============================================

# HTTP basic auth username for OpenCode server
#OPENCODE_SERVER_USERNAME=opencode

# HTTP basic auth password for OpenCode server
#OPENCODE_SERVER_PASSWORD=your_password_here

# Additional CORS domains for OpenCode server
#OPENCODE_CORS=https://example.com,https://another.com