# Copy this file to .env and fill in your API keys.
# .env is gitignored — never commit actual keys.
#
# The Docker container reads these via docker-compose.yml variable substitution.
# After editing .env, run: docker compose down && docker compose up -d

# Model selection — leave blank to use the opencode.json default (deepseek/deepseek-chat)
# Examples: deepseek/deepseek-reasoner, deepseek/deepseek-chat, anthropic/claude-sonnet-4-6, openai/gpt-4o
OPENCODE_MODEL=

# AI provider API keys
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
