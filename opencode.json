{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "lean": {
      "type": "local",
      "command": [
        "bash",
        ".mcp/lean-tools/run.sh"
      ],
      "enabled": true,
      "timeout": 15000
    },
    "lean_lsp": {
      "type": "local",
      "command": [
        "bash",
        "-c",
        "LEAN_LOOGLE_LOCAL=false .mcp/run-lean-lsp-mcp.sh"
      ],
      "enabled": true,
      "timeout": 60000
    }
  }
}
